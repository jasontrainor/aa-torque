<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    android:background="@android:color/black">

    <!-- Landscape-ratio preview strip at the top, full screen width -->
    <FrameLayout
        android:id="@+id/preview_wrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:layout_constraintDimensionRatio="H,8:3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.fragment.app.FragmentContainerView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:name="com.aatorque.stats.DashboardFragment"
            android:background="@drawable/background_incar_black"
            android:id="@+id/preview_container" />

    </FrameLayout>

    <!-- Scrollable control panel below the preview -->
    <ScrollView
        android:id="@+id/theme_builder_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DD000000"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/preview_wrapper"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theme Designer"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <!-- Gauge selector row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selected Gauge"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btn_gauge_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="G1"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_gauge_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="G2"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_gauge_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="G3" />

            </LinearLayout>

            <!-- Per-gauge: rotation -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gauge Rotation"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <SeekBar
                    android:id="@+id/seekbar_rotation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="360"
                    android:progress="0" />

                <TextView
                    android:id="@+id/text_rotation_value"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="0°"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Per-gauge: flip sweep direction -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Flip Sweep Direction"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:gravity="center_vertical" />

                <Switch
                    android:id="@+id/switch_flip_sweep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />

            </LinearLayout>

            <!-- Per-gauge: size -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gauge Size"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <SeekBar
                    android:id="@+id/seekbar_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="50" />

                <TextView
                    android:id="@+id/text_size_value"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:gravity="end"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

            <!-- Per-gauge: gauge style / shape -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gauge Style"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/gauge_shape_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/shape_circular"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Circular"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/shape_bar_h"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bar H"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/shape_bar_v"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bar V"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

            </RadioGroup>

            <!-- Per-gauge: needle style -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Needle Style"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/needle_style_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/needle_dot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Dot"
                    android:checked="true"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/needle_line"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Line"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/needle_triangle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Triangle"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

            </RadioGroup>

            <!-- Per-gauge: background style -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Background Style"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <RadioGroup
                android:id="@+id/bg_style_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/bg_arc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Arc"
                    android:checked="true"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/bg_none"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="None"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

                <RadioButton
                    android:id="@+id/bg_filled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Filled"
                    android:textColor="@android:color/white"
                    android:buttonTint="@android:color/white" />

            </RadioGroup>

            <!-- Per-gauge: drag hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drag gauges in the preview above to reposition — they snap to a grid"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <!-- Color Presets Row -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Color Presets (applies to selected gauge)"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/preset_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="4dp" />

            </HorizontalScrollView>

            <!-- Color Picker Buttons -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom Colors"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <Button
                    android:id="@+id/btn_bg_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BG"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_accent_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Accent"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_needle_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Needle"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_redline_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Redline" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
