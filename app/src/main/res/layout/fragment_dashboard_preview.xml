<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Landscape-ratio preview strip at the top, full screen width -->
    <FrameLayout
        android:id="@+id/preview_wrapper"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/black"
        app:layout_constraintDimensionRatio="H,8:3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/preview_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:name="com.aatorque.stats.DashboardFragment"
            android:background="@drawable/background_incar_black" />

        <ImageButton
            android:id="@+id/btn_fullscreen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="end|top"
            android:layout_margin="8dp"
            android:src="@drawable/baseline_preview_24"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Fullscreen preview" />

    </FrameLayout>

    <!-- Screen navigation bar -->
    <LinearLayout
        android:id="@+id/screen_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1A1A1A"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/preview_wrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_prev_screen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Previous screen" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/text_screen_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen 1 of 1"
                android:textColor="#888888"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/edit_screen_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Screen title"
                android:textColor="@android:color/white"
                android:textColorHint="#555555"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@null"
                android:imeOptions="actionDone"
                android:inputType="textCapSentences"
                android:maxLines="1" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_next_screen"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@android:color/white"
            android:contentDescription="Next screen" />

    </LinearLayout>

    <!-- Scrollable control panel below the screen bar -->
    <ScrollView
        android:id="@+id/theme_builder_panel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#DD000000"
        app:layout_constraintTop_toBottomOf="@id/screen_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- ── CARD 1: Dashboard ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_background_picker"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Background"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/btn_font_picker"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Font" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── CARD 2: Gauge ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gauge"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drag gauges in the preview to reposition"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Gauge selector + add/remove -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <Button
                            android:id="@+id/btn_gauge_1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="G1"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btn_gauge_2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="G2"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btn_gauge_3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="G3"
                            android:layout_marginEnd="8dp" />

                        <Button
                            android:id="@+id/btn_add_gauge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+"
                            android:textSize="18sp"
                            android:minWidth="0dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="4dp" />

                        <Button
                            android:id="@+id/btn_remove_gauge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="−"
                            android:textSize="18sp"
                            android:minWidth="0dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />

                    </LinearLayout>

                    <!-- Gauge Style chips -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gauge Style"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/gauge_shape_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_shape_circular"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Round"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_shape_bar_h"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="H Bar" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_shape_bar_v"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="V Bar" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_shape_text"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Text" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Rotation -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rotation"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <SeekBar
                            android:id="@+id/seekbar_rotation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="360"
                            android:progress="0" />

                        <TextView
                            android:id="@+id/text_rotation_value"
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="0°"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:gravity="end"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Flip sweep direction -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Flip Sweep Direction"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_flip_sweep"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />

                    </LinearLayout>

                    <!-- Gauge Size -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gauge Size"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <SeekBar
                            android:id="@+id/seekbar_size"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="150"
                            android:progress="50" />

                        <TextView
                            android:id="@+id/text_size_value"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:text="100%"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:gravity="end"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── CARD 3: Appearance ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appearance"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Needle Style chips -->
                    <TextView
                        android:id="@+id/label_needle_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Needle Style"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/needle_style_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_needle_dot"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dot"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_needle_line"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Line" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_needle_triangle"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Triangle" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_needle_image"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Image" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Needle / dial image pickers — shown only when Image needle is selected -->
                    <Button
                        android:id="@+id/btn_needle_image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Needle Image"
                        android:visibility="gone"
                        android:layout_marginBottom="4dp" />

                    <Button
                        android:id="@+id/btn_dial_bg_image"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Dial Background"
                        android:visibility="gone"
                        android:layout_marginBottom="12dp" />

                    <!-- Background Style chips -->
                    <TextView
                        android:id="@+id/label_bg_style"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Background Style"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/bg_style_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_bg_arc"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Arc"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_bg_none"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="None" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_bg_filled"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Filled" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Gauge icon picker -->
                    <Button
                        android:id="@+id/btn_gauge_icon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select Icon"
                        android:layout_marginBottom="12dp" />

                    <!-- Title Font Size -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Title Font Size"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <SeekBar
                            android:id="@+id/seekbar_title_size"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="16"
                            android:progress="4" />

                        <TextView
                            android:id="@+id/text_title_size_value"
                            android:layout_width="52dp"
                            android:layout_height="wrap_content"
                            android:text="12sp"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:gravity="end"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── CARD 4: Colors ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A1A1A"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Colors"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Preset swatches -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Presets"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:id="@+id/preset_row"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingBottom="4dp" />

                    </HorizontalScrollView>

                    <!-- Apply to all gauges toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Apply to all gauges"
                            android:textColor="@android:color/white"
                            android:textSize="14sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_apply_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false" />

                    </LinearLayout>

                    <!-- Custom color pickers — 2×2 grid of labeled swatches -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custom Colors"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="8dp" />

                    <!-- Row 1: Background + Accent -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:id="@+id/swatch_bg"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/circle_bg_color"
                                android:layout_width="48dp"
                                android:layout_height="48dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Background"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/swatch_accent"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/circle_accent_color"
                                android:layout_width="48dp"
                                android:layout_height="48dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Accent"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Row 2: Needle + Redline -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/swatch_needle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/circle_needle_color"
                                android:layout_width="48dp"
                                android:layout_height="48dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Needle"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/swatch_redline"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground">

                            <ImageView
                                android:id="@+id/circle_redline_color"
                                android:layout_width="48dp"
                                android:layout_height="48dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Redline"
                                android:textColor="#AAAAAA"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

